<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Cyra Calendar | Privacy Policy</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
font-family:'Poppins',sans-serif;
}

body{

background:
radial-gradient(circle at top,#12253d,#060b18 60%,#04060f);

color:#fff;

overflow-x:hidden;

}

/* Background */

body::before{

content:"";

position:fixed;

width:600px;
height:600px;

background:#16ff7a22;

filter:blur(180px);

left:-150px;
top:-150px;

z-index:-2;

}

body::after{

content:"";

position:fixed;

width:500px;
height:500px;

background:#ff313122;

filter:blur(160px);

right:-100px;
bottom:-100px;

z-index:-2;

}

/* Hero */

.hero{

padding:70px 20px 40px;

text-align:center;

}

/* CBT LOGO */

.logo{

font-size:95px;

font-weight:800;

letter-spacing:6px;

display:inline-flex;

gap:10px;

}

.logo span{

display:inline-block;

animation:float 2.5s ease-in-out infinite;

}

.logo span:nth-child(1){

color:#FFD600;

text-shadow:

0 0 20px #FFD600,

0 0 45px #FFD600;

animation-delay:.1s;

}

.logo span:nth-child(2){

color:#21ff66;

text-shadow:

0 0 20px #21ff66,

0 0 45px #21ff66;

animation-delay:.3s;

}

.logo span:nth-child(3){

color:#ff3434;

text-shadow:

0 0 20px #ff3434,

0 0 45px #ff3434;

animation-delay:.5s;

}

@keyframes float{

0%{

transform:translateY(0px);

}

50%{

transform:translateY(-10px);

}

100%{

transform:translateY(0px);

}

}

h1{

margin-top:18px;

font-size:42px;

font-weight:700;

}

.subtitle{

font-size:22px;

margin-top:8px;

background:linear-gradient(90deg,#FFD600,#21ff66,#ff3434);

-webkit-background-clip:text;

color:transparent;

font-weight:600;

}

/* Glass Card */

.container{

max-width:1100px;

margin:50px auto;

padding:20px;

}

.card{

background:rgba(255,255,255,.08);

border:1px solid rgba(255,255,255,.12);

backdrop-filter:blur(25px);

border-radius:28px;

padding:35px;

box-shadow:

0 20px 50px rgba(0,0,0,.4);

}

.section{

margin-bottom:40px;

}

.section h2{

font-size:28px;

margin-bottom:15px;

color:#ffffff;

}

.section p{

line-height:1.9;

color:#dddddd;

font-size:17px;

}

.badge{

display:inline-block;

padding:8px 16px;

border-radius:50px;

background:#16ff7a22;

color:#16ff7a;

margin-bottom:20px;

font-size:14px;

}

footer{

text-align:center;

padding:40px 20px;

color:#bbb;

}

.contact{

margin-top:15px;

font-size:18px;

color:#21ff66;

}

@media(max-width:768px){

.logo{

font-size:60px;

}

h1{

font-size:30px;

}

.subtitle{

font-size:18px;

}

.card{

padding:25px;

}

}

</style>

</head>

<body>

<section class="hero">

<div class="logo">

<span>C</span>

<span>B</span>

<span>T</span>

</div>

<h1>Cyra Calendar</h1>

<div class="subtitle">

Privacy Policy

</div>

</section>

<div class="container">

<div class="card">

<div class="badge">

Last Updated: June 2026

</div>

<div class="section">

<h2>Introduction</h2>

<p>

Welcome to Cyra Calendar.

Your privacy is important to us.

This Privacy Policy explains how our application handles information while providing a secure and reliable calendar experience.

</p>

</div>

<!-- More sections will be added in Part 2 -->
<!-- Information We Collect -->

<div class="section">

<h2>Information We Collect</h2>

<p>

Cyra Calendar is designed with privacy in mind.

We do not collect personal information such as your name, phone number, email address, photos, contacts or calendar events.

</p>

<p style="margin-top:15px;">

Some anonymous technical information may be collected automatically by trusted third-party services such as Google AdMob to display advertisements and improve service quality.

</p>

</div>

<!-- Local Storage -->

<div class="section">

<h2>Local Data Storage</h2>

<p>

All calendar events, reminders and settings created inside Cyra Calendar are stored locally on your device.

Your personal calendar data is never uploaded to our servers.

</p>

</div>

<!-- Advertising -->

<div class="section">

<h2>Advertising (Google AdMob)</h2>

<p>

Cyra Calendar displays Banner Ads and Interstitial Ads using Google AdMob.

Google and its partners may collect device identifiers, advertising identifiers and limited diagnostic information to provide personalized or non-personalized advertisements according to their own Privacy Policy.

</p>

</div>

<!-- Third Party -->

<div class="section">

<h2>Third-Party Services</h2>

<p>

Our application may use trusted third-party services including:

</p>

<ul style="margin-top:15px;padding-left:25px;line-height:2;color:#ddd;">

<li>Google AdMob</li>

<li>Google Play Services</li>

</ul>

</div>

<!-- Permissions -->

<div class="section">

<h2>Permissions</h2>

<p>

Cyra Calendar only requests permissions that are necessary for the application to function properly.

</p>

<ul style="margin-top:15px;padding-left:25px;line-height:2;color:#ddd;">

<li>Notification Permission (Reminder Alerts)</li>

<li>Exact Alarm Permission (If supported)</li>

</ul>

<p style="margin-top:15px;">

The app does NOT request Camera, Microphone or Location permissions.

</p>

</div>

<!-- Data Security -->

<div class="section">

<h2>Data Security</h2>

<p>

We take reasonable measures to protect your information.

Since your calendar data remains on your own device, you have full control over your information.

</p>

</div>

<!-- Children's Privacy -->

<div class="section">

<h2>Children's Privacy</h2>

<p>

Cyra Calendar is not directed to children under the age of 13.

We do not knowingly collect personal information from children.

</p>

</div>

<!-- Changes -->

<div class="section">

<h2>Changes to This Privacy Policy</h2>

<p>

We may update this Privacy Policy from time to time.

Any changes will be published on this page together with the updated effective date.

</p>

</div>

<!-- Contact -->

<div class="section">

<h2>Contact Us</h2>

<p>

If you have any questions regarding this Privacy Policy, please contact us.

</p>

<p style="margin-top:20px;font-weight:600;color:#21ff66;">

Email:

cybrotechnology1@gmail.com

</p>

</div>

</div>

</div>

<footer>

© 2026 CBT.

All Rights Reserved.

<div class="contact">

Support:

cybrotechnology1@gmail.com

</div>

</footer>

<script>

// Part 3 এ সম্পূর্ণ Animation ও Interactive Features যোগ হবে
/* ============================
   PREMIUM JAVASCRIPT
============================ */

const logoLetters = document.querySelectorAll(".logo span");

logoLetters.forEach((letter,index)=>{

setInterval(()=>{

letter.animate([

{

transform:"translateY(0px) scale(1)",

filter:"brightness(1)"

},

{

transform:"translateY(-10px) scale(1.08)",

filter:"brightness(1.5)"

},

{

transform:"translateY(0px) scale(1)",

filter:"brightness(1)"

}

],{

duration:1500,

delay:index*200

});

},1800);

});

/* Scroll Animation */

const sections=document.querySelectorAll(".section");

const observer=new IntersectionObserver(entries=>{

entries.forEach(entry=>{

if(entry.isIntersecting){

entry.target.animate([

{

opacity:0,

transform:"translateY(60px)"

},

{

opacity:1,

transform:"translateY(0px)"

}

],{

duration:700,

fill:"forwards"

});

}

});

});

sections.forEach(sec=>observer.observe(sec));

/* Floating Particles */

for(let i=0;i<35;i++){

let dot=document.createElement("div");

dot.style.position="fixed";

dot.style.width="4px";

dot.style.height="4px";

dot.style.borderRadius="50%";

dot.style.background="rgba(255,255,255,.4)";

dot.style.left=Math.random()*100+"vw";

dot.style.top=Math.random()*100+"vh";

dot.style.pointerEvents="none";

dot.style.zIndex="-1";

dot.animate([

{

transform:"translateY(0px)",

opacity:.2

},

{

transform:"translateY(-120px)",

opacity:1

},

{

transform:"translateY(-250px)",

opacity:0

}

],{

duration:4000+Math.random()*4000,

iterations:Infinity

});

document.body.appendChild(dot);

}

/* Last Updated */

const badge=document.querySelector(".badge");

const d=new Date();

badge.innerHTML="Last Updated : "+d.toDateString();

/* Back To Top */

const btn=document.createElement("button");

btn.innerHTML="↑";

btn.style.position="fixed";

btn.style.right="25px";

btn.style.bottom="25px";

btn.style.width="55px";

btn.style.height="55px";

btn.style.borderRadius="50%";

btn.style.border="none";

btn.style.cursor="pointer";

btn.style.fontSize="24px";

btn.style.color="#fff";

btn.style.background="linear-gradient(45deg,#FFD600,#21ff66,#ff3434)";

btn.style.boxShadow="0 0 25px rgba(255,255,255,.25)";

btn.style.display="none";

btn.style.zIndex="999";

document.body.appendChild(btn);

window.addEventListener("scroll",()=>{

btn.style.display=window.scrollY>350?"block":"none";

});

btn.onclick=()=>{

window.scrollTo({

top:0,

behavior:"smooth"

});

};

/* Loading Animation */

window.onload=()=>{

document.body.animate([

{

opacity:0

},

{

opacity:1

}

],{

duration:700,

fill:"forwards"

});

};
</script>

</body>

</html>
